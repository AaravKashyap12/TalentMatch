# Backend environment for Render or local API

# App database. Local dev can use SQLite; production should use Render Postgres.
DATABASE_URL=sqlite+aiosqlite:///./talentmatch.db

# Supabase Auth. Required in production because the frontend uses Supabase email/password
# and Google OAuth. This project does not use Supabase as the main app database.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Backend secrets
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRATION_HOURS=24
ADMIN_SECRET=change-me-admin-secret

# CORS. Set this to every deployed frontend origin that should call the API.
# Example: https://talentmatch.yourdomain.com,https://your-vercel-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Product limits
FREE_SCAN_LIMIT=5
MAX_UPLOAD_SIZE_MB=20
MAX_FILES_PER_SCAN=20
MAX_JOB_DESCRIPTION_CHARS=10000
MAX_JD_FILE_SIZE_KB=256

# Optional Groq AI integration. Blank GROQ_API_KEY keeps deterministic scoring active
# but disables Groq-assisted JD parsing and candidate overviews.
ENABLE_GROQ_JD_PARSING=true
ENABLE_GROQ_OVERVIEWS=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=8
GROQ_MAX_JD_CHARS=6000

# Local only. Never enable this in production.
DEV_MODE=false

# Frontend variables belong in web/.env or Vercel Project Settings.
# VITE_API_BASE_URL=https://your-render-api.onrender.com/api/v1
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# VITE_ENABLE_ADMIN_DASHBOARD=false
